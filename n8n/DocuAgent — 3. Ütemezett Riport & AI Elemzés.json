    {
      "parameters": {
        "sendTo": "=huszarviktordev@gmail.com",
        "subject": "=📊 Heti AI Aktivitási Riport — {{$now.format('yyyy. MM. dd.')}}",
        "message": "=<h2>📊 Heti DocuAgent Riport</h2>\n\n<p><b>Időszak:</b>{{ $('Statisztika Aggregálás').item.json.period }}</p>\n\n<table border=\"1\" cellpadding=\"8\" style=\"border-collapse:collapse; width:100%\">\n  <tr style=\"background:#1F3864; color:white\">\n    <th>Metrika</th>\n    <th>Érték</th>\n  </tr>\n  <tr>\n    <td>📧 Kezelt emailek</td>\n    <td>{{ $('Statisztika Aggregálás').item.json.email.total }}</td>\n  </tr>\n  <tr style=\"background:#f2f2f2\">\n    <td>⚠️ Panaszok</td>\n    <td>{{ $('Statisztika Aggregálás').item.json.email.complaints }}</td>\n  </tr>\n  <tr>\n    <td>❓ Érdeklődések</td>\n    <td>{{ $('Statisztika Aggregálás').item.json.email.inquiries }}</td>\n  </tr>\n  <tr style=\"background:#f2f2f2\">\n    <td>🚨 Sürgős esetek</td>\n    <td>{{ $('Statisztika Aggregálás').item.json.email.urgent }}</td>\n  </tr>\n  <tr>\n    <td>📄 Feldolgozott dok.</td>\n    <td>{{ $('Statisztika Aggregálás').item.json.documents.total }}</td>\n  </tr>\n</table>\n\n<h3>🤖 AI Elemzés</h3>\n\n<div style=\"background:#f8f9fa; padding:16px; border-left:4px solid #2E75B6\">\n{{ $json.message.content }}\n</div>\n\n<hr>\n\n<small style=\"color:#888\">\nDocuAgent Automatikus Riport — {{$now.format('yyyy. MM. dd. HH:mm')}}\n</small>",
        "options": {
          "appendAttribution": false
        }
