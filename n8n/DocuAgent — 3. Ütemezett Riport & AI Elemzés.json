    {
      "parameters": {
        "jsCode": "// Email statisztikák\nconst emails = $('Email Log Olvasás').all().map(i => i.json);\nconst docs = $('Dokumentum Log Olvasás').all().map(i => i.json);\n\n// Az elmúlt 7 nap\nconst weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\nconst recentEmails = emails.filter(e => new Date(e['Időpont']) > weekAgo);\nconst recentDocs = docs.filter(d => new Date(d['Időpont']) > weekAgo);\n\n// Email kategória bontás\nconst complaints = recentEmails.filter(e => e['Kategória'] === 'complaint').length;\nconst inquiries = recentEmails.filter(e => e['Kategória'] === 'inquiry').length;\nconst urgent = recentEmails.filter(e => e['Sürgős'] === 'true' || e['Sürgős'] === true).length;\n\nconst summary = {\n  period: `${weekAgo.toLocaleDateString('hu-HU')} – ${new Date().toLocaleDateString('hu-HU')}`,\n  email: {\n    total: recentEmails.length,\n    complaints,\n    inquiries,\n    general: recentEmails.length - complaints - inquiries,\n    urgent\n  },\n  documents: {\n    total: recentDocs.length,\n    uploaders: [...new Set(recentDocs.map(d => d['Feltöltő']))].length\n  },\n  raw_email_sample: recentEmails.slice(0, 5).map(e => `${e['Tárgy']} (${e['Kategória']})`).join('\\n')\n};\n\nreturn [{ json: summary }];"
      },
      "id": "3bc20846-ecf6-4b9e-be83-32383f8f59e2",
