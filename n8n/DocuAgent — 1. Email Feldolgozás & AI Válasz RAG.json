{
  "name": "DocuAgent — 1. Email Feldolgozás & AI Válasz RAG",
  "nodes": [
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const subject = $json.Subject || '';\nconst from = $json.From || '';\nconst body = $json.text || $json.snippet || '';\n\nconst isComplaint = /panasz|probléma|nem működik|hibás|reklamáció/i.test(body + subject);\nconst isInquiry = /árajánlat|kérdés|érdeklődöm|információ/i.test(body + subject);\nconst isUrgent = /sürgős|azonnali|urgent|asap/i.test(body + subject);\n\nreturn {\n  json: {\n    subject,\n    from,\n    body: body.substring(0, 2000),\n    category: isComplaint ? 'complaint' : isInquiry ? 'inquiry' : 'general',\n    isUrgent,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "3cd4ce89-0133-40a9-b5f3-8cc817f1da5a",
      "name": "🔍 Email Kategorizálás",
      "type": "n8n-nodes-base.code",
