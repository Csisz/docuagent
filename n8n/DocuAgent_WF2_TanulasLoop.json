            "Feedback db": "={{ $('🔀 Adatok Összefésülése').item.json.stats.feedback }}",
            "Avg konfidencia": "={{ $('🔀 Adatok Összefésülése').item.json.stats.avg_conf }}",
            "RAG fallback %": "={{ $('🔀 Adatok Összefésülése').item.json.stats.rag_rate }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "cAOPh4Cw14zWIgrP",
