    {
      "id": "wf2-merge",
      "name": "🔀 Adatok Összefésülése",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        304
      ],
      "parameters": {
        "jsCode": "\nconst dash = $('📊 Backend Statisztikák').first().json;\nconst rag  = $('🔎 RAG Statisztikák').first().json;\n\nconst kpis    = dash.kpis    || {};\nconst status  = dash.status_breakdown || {};\nconst alerts  = dash.alerts  || [];\nconst ragSum  = rag.summary  || {};\n\nconst total       = kpis.emails?.value         || 0;\nconst ai_answered = kpis.ai_answered?.value    || 0;\nconst needs_att   = kpis.needs_attention?.value|| 0;\nconst feedback    = kpis.feedback_total?.value || 0;\nconst avg_conf    = kpis.avg_confidence?.value || 0;\n\nconst rag_total   = ragSum.total_queries    || 0;\nconst rag_fallback= ragSum.fallback_count   || 0;\nconst rag_rate    = ragSum.fallback_rate_pct|| 0;\n\nconst auto_rate   = total > 0 ? Math.round(ai_answered / total * 100) : 0;\nconst needs_rate  = total > 0 ? Math.round(needs_att   / total * 100) : 0;\n\n// Riport szöveg\nconst lines = [\n  `*📊 DocuAgent — Tanulási Riport*`,\n  `_${new Date().toLocaleString('hu-HU')}_`,\n  ``,\n  `*Email feldolgozás (utolsó 7 nap):*`,\n  `• Összes email: ${total}`,\n  `• AI által megválaszolva: ${ai_answered} (${auto_rate}%)`,\n  `• Figyelmet igényel: ${needs_att} (${needs_rate}%)`,\n  `• Átlag konfidencia: ${avg_conf}%`,\n  `• Feedback korrekciók: ${feedback}`,\n  ``,\n  `*RAG lekérdezések (ma):*`,\n  `• Összes: ${rag_total}`,\n  `• Fallback (nem talált): ${rag_fallback} (${rag_rate}%)`,\n];\n\nif (alerts.length > 0) {\n  lines.push('');\n  lines.push('*⚠️ Figyelmeztetések:*');\n  alerts.forEach(a => lines.push(`• ${a.message.replace(/<[^>]*>/g,'')}`));\n}\n\n// Tanulási ajánlások\nlines.push('');\nlines.push('*🧠 Tanulási állapot:*');\nif (feedback === 0) {\n  lines.push('• Még nincs feedback korrekció — a rendszer az alap promptot használja');\n} else if (feedback < 5) {\n  lines.push(`• ${feedback} korrekció rögzítve — tanulás beindult`);\n} else {\n  lines.push(`• ${feedback} korrekció rögzítve — aktív tanulási mód`);\n}\n\nif (rag_rate > 50) {\n  lines.push(`• ⚠️ Magas fallback arány (${rag_rate}%) — érdemes több dokumentumot feltölteni`);\n}\nif (auto_rate < 50 && total > 10) {\n  lines.push(`• ⚠️ Alacsony auto-válasz arány (${auto_rate}%) — ellenőrizd a confidence threshold-ot`);\n}\nif (auto_rate >= 80) {\n  lines.push(`• ✅ Kiváló automatizáltság (${auto_rate}%)`);\n}\n\nreturn [{\n  json: {\n    report_text: lines.join('\\n'),\n    stats: { total, ai_answered, needs_att, feedback, avg_conf, auto_rate, rag_total, rag_fallback, rag_rate },\n    has_alerts: alerts.length > 0,\n    needs_attention: needs_att > 0 || rag_rate > 50\n  }\n}];\n"
      }
    },
    {
      "id": "wf2-if-alert",
      "name": "⚡ Van figyelmeztetés?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        720,
        304
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-alert",
              "leftValue": "={{ $json.needs_attention }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "or"
        }
      }
    },
