    {
      "id": "wf2-get-rag",
      "name": "🔎 RAG Statisztikák",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        272,
        480
      ],
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:8000/api/rag-stats?days=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.DASHBOARD_API_KEY }}"
            }
          ]
        },
        "options": {}
