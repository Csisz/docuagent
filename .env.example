# DocuAgent v3.2 — Environment Variables
# Copy: cp .env.example .env  then fill in values
# NEVER commit the filled .env file!

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docuagent

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── n8n ──────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_PASSWORD=changeme
N8N_ENCRYPTION_KEY=  # openssl rand -hex 32
WEBHOOK_URL=http://localhost:5678/
# N8N_LABEL_WEBHOOK=http://n8n:5678/webhook/gmail-label-sync
N8N_LABEL_WEBHOOK=http://n8n:5678/webhook/gmail-label-sync

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── App ──────────────────────────────────────────────────────
COMPANY_NAME=Agentify Kft.
PORT=8000
CONFIDENCE_THRESHOLD=0.70

# ── Biztonság (v3.2) ─────────────────────────────────────────
# Dashboard és API végpontok védelme
# Ha üresen hagyod, az auth ki van kapcsolva (fejlesztői mód)
# Generálj erős kulcsot: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_KEY=

# CORS: vesszővel elválasztott engedélyezett domain-ek
# Fejlesztéshez: * | Production: https://dashboard.agentify.hu
ALLOWED_ORIGINS=*

# ── Google (for Gmail + Sheets) ──────────────────────────────
GOOGLE_SHEET_ID=
REPORT_EMAIL=

# ── Slack (optional) ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── RAG / Fallback (v3.3) ─────────────────────────────────────
# Ha a keresési confidence ez alá esik → sablon válasz megy ki (0.0-1.0)
RAG_FALLBACK_THRESHOLD=0.45

# Sablon válaszok - ha nincs elég biztos találat
FALLBACK_REPLY_HU=Köszönjük megkeresését! Utánanézünk és hamarosan visszajelzünk Önnek.
FALLBACK_REPLY_EN=Thank you for reaching out! We will look into this and get back to you shortly.
FALLBACK_REPLY_DE=Vielen Dank für Ihre Anfrage! Wir werden uns darum kümmern und uns bald bei Ihnen melden.
